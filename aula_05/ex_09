#include <stdio.h>

int main() {
    int v[10];

    for(int i = 0; i < 10; i++) {
        printf("Digite um numero: ");
        scanf("%d", &v[i]);
    }

    for(int i = 0; i < 10; i++) {
        if(v[i] < 0) {
            v[i] = 0;
        }
    }

    printf("Vetor atualizado:\n");
    for(int i = 0; i < 10; i++) {
        printf("%d ", v[i]);
    }

    return 0;
}