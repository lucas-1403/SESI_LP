#include <stdio.h>

int main() {
    int v[10];
    float soma = 0, media;

    for(int i = 0; i < 10; i++) {
        printf("Digite um numero: ");
        scanf("%d", &v[i]);
        soma += v[i];
    }

    media = soma / 10;

    printf("Media = %.2f\n", media);
    printf("Valores maiores que a media:\n");

    for(int i = 0; i < 10; i++) {
        if(v[i] > media) {
            printf("%d ", v[i]);
        }
    }

    return 0;
}