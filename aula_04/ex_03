#include <stdio.h>

int main() {
    int v[12];
    int cres = 0, decres = 0;

    printf("Digite 12 valores:\n");
    for (int i = 0; i < 12; i++) {
        scanf("%d", &v[i]);
    }

    
    for (int i = 0; i < 11; i++) {
        if (v[i] < v[i + 1]) cres = 1;   
        if (v[i] > v[i + 1]) decres = 1; 
    }

    printf("\nResultado: ");
    if (cres == 1 && decres == 0) 
        printf("Ordem Crescente\n");
    else if (decres == 1 && cres == 0) 
        printf("Ordem Decrescente\n");
    else if (cres == 0 && decres == 0) 
        printf("Constante\n");
    else 
        printf("Desordenada\n");

}