#include <stdio.h>

int main() {
    float t[7], s = 0, med, max, min;
    int i, ac = 0;

   
    for (i = 0; i < 7; i++) {
        scanf("%f", &t[i]);
        s += t[i];
    }

    med = s / 7;
    max = min = t[0]; 

    
    for (i = 0; i < 7; i++) {
        if (t[i] > max) max = t[i];
        if (t[i] < min) min = t[i];
        if (t[i] > med) ac++;
    }
   
    printf("Media: %.2f\n", med);
    printf("Max: %.1f | Min: %.1f\n", max, min);
    printf("Acima da media: %d\n", ac);

    return 0;
}