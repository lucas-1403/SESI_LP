#include <stdio.h>

/*3) Leia dois números inteiros e informe qual é o maior ou se são iguais.*/

int main() {

	int n1, n2;

	printf("digite o primeiro numero: ");
	scanf("%i", &n1);

	printf("digite segundo numero: ");
	scanf("%i", &n2);

	if(n1 > n2) {
		printf("%i maior", n1);

	} else if(n1 < n2) {
		printf("%i maior", n2);

	} else {
		printf("são iguais!");
	}
}