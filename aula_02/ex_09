#include<stdio.h>

/*9) Número Positivo, Negativo ou Zero
Leia um número e informe se ele é:
Positivo
Negativo
Zero*/

int main(){
    float num;
    
    printf("digite o numero: ");
    scanf("%f", &num);
    
    if(num > 0){
        printf("positivo");
        
    }else if(num < 0){
        printf("negativo");
        
    } else{
        printf("zero");
    }
}