#include <stdio.h>

int main() {
    int num, maior;

    printf("Digite um numero (999 para parar): ");
    scanf("%d", &num);

    maior = num;

    while (num != 999) {
        if (num > maior)
            maior = num;

        printf("Digite outro numero: ");
        scanf("%d", &num);
    }

    printf("Maior numero: %d\n", maior);

    return 0;
}