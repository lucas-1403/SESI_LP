#include<stdio.h>

void main(){
    int N1, N2;
    int i=0;
    int soma=0;
 
 printf("digite o primeiro numero:");
 scanf("%i", &N1);
 
 printf("digite o segundo numero:");
 scanf("%i", &N2);
 
 while(i < N1){
     printf("%i \n", soma);
     soma += i;
     i++;
 }
 soma = 0;
 i = 0;
 
 while(i < N2){
     printf("%i \n", soma);
     soma += i;
     i++;
 }
}