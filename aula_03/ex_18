#include <stdio.h>

int main() {
    int idade, soma = 0, count = 0;

    do {
        printf("Digite uma idade (0 para parar): ");
        scanf("%d", &idade);

        if (idade != 0) {
            soma += idade;
            count++;
        }
    } while (idade != 0);

    if (count > 0)
        printf("Media: %.2f\n", (float)soma / count);
    else
        printf("Nenhuma idade foi digitada.\n");

}