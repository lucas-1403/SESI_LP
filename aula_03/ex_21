#include <stdio.h>

int main() {
    int opcao;

    do {
        printf("\n1: Ola\n2: Tudo bem?\n3: Sair\nEscolha: ");
        scanf("%d", &opcao);

        if (opcao == 1)
            printf("Ola!\n");
        else if (opcao == 2)
            printf("Tudo bem?\n");

    } while (opcao != 3);

    return 0;
}