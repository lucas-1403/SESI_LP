#include <stdio.h>

int main()
{
    // int vetor[10] = {7,1,2,4,9,5,6,8,10,3};
    int vetor[10];
    int i = 0;
    int j = 0;
    int temp = 0;
    
    
    while(i < 10){
        printf("digite um numero:");
        scanf("%i", &vetor[i]);
        
        i++;
    }
    
    i=0;
    
    while( i < 9){
      j= i + 1;
      while( j  < 10){
        if(vetor[i] > vetor[j]){
            temp = vetor[i];
            vetor[i] = vetor[j];
            vetor[j] = temp;
        }  
        j++;
      }
      i++;
    }
  
  i = 0;
  printf("\n aqui esta a ordem crescente: ");
  while( i < 10){
    printf("\n%i", vetor[i]);
    
    i++;
  }
  
