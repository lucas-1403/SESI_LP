#include <stdio.h>

int main() {
    int m[5][5];
    int i, j, soma = 0;

   
    for(i = 0; i < 5; i++) {
        for(j = 0; j < 5; j++) {
            scanf("%d", &m[i][j]);
        }
    }

   
    for(i = 0; i < 5; i++) {
        soma += m[i][4 - i];
    }

    printf("Soma: %d\n", soma);

    return 0;
}