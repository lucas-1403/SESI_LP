
#include<stdio.h>

int main(){
    int matriz[2][2];
    int soma = 0;
    
    for(int l=0; l < 2; l++){
        for(int c=0; c < 2; c++){
            printf("digite valor de l:%i, c:%i :", l+1, c+1);
            scanf("%i", &matriz[l][c]);
            soma += matriz[l][c];
        }
    }
    
    printf("----------------------------");
    printf("\n");
    
    int l=0;
    int c=0;
    
    for(l=0; l<2; l++){
        for(c=0; c<2; c++){
            printf(" | %i", matriz[l][c]);
        }
        printf("\n");
    }
    
    printf("a soma total é igual a: %i", soma);
    
}