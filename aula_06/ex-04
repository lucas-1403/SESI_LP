#include <stdio.h>

int main(){
    int matriz[4][4];

    for(int l = 0; l < 4; l++){
        for(int c = 0; c < 4; c++){
            printf("Digite valor de l:%i, c:%i: ", l+1, c+1);
            scanf("%i", &matriz[l][c]);
        }
    }

    printf("----------------------------\n");

    for(int l = 0; l < 4; l++){
        for(int c = 0; c < 4; c++){
            printf(" | %i", matriz[l][c]);
        }
        printf("\n");
    }

    printf("\nNumeros maiores ou iguais a 10:\n");

    for(int l = 0; l < 4; l++){
        for(int c = 0; c < 4; c++){
            if(matriz[l][c] >= 10){
                printf("Valor %i na posicao [%i][%i]\n",
                       matriz[l][c], l+1, c+1);
            }
        }
    }

}